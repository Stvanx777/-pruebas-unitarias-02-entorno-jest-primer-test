{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./",
    "types": ["jest", "node"]          // ← Esta es la línea más importante
  },
  "include": ["src/**/*", "tests/**/*"],   // ← Agrega "tests/**/*" aquí
  "exclude": ["node_modules", "dist"]
}